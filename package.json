{
  "name": "@deveasyclick/billpay",
  "version": "0.1.0",
  "description": "Framework-agnostic Node.js SDK for bill payment processing with automatic provider failover",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepublishOnly": "npm run build",
    "test": "ts-node tests/client-usage.ts",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "billpay",
    "payment",
    "interswitch",
    "vtpass",
    "airtime",
    "data",
    "electricity",
    "tv",
    "gaming",
    "Nigeria",
    "failover"
  ],
  "author": "deveasyclick",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/deveasyclick/billpay-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/deveasyclick/billpay-sdk/issues"
  },
  "homepage": "https://github.com/deveasyclick/billpay-sdk#readme",
  "dependencies": {
    "axios": "^1.6.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
